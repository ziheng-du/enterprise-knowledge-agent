# =============================================================================
# 企业智能知识助手 — 环境变量示例文件
# 使用方式：复制本文件为 .env，并填入真实值。.env 已被 .gitignore 忽略，
# 禁止将真实密钥提交到版本库。
# 所有配置项与 app/config.py 中的 Settings 字段一一对应（不区分大小写）。
# =============================================================================

# --- LLM（OpenAI 兼容接口，如通义千问 / DeepSeek） ---
# LLM API 密钥（必填，否则涉及 LLM 的功能无法使用）
LLM_API_KEY=sk-your-api-key-here
# LLM API Base URL（OpenAI 兼容格式）
LLM_BASE_URL=https://api.deepseek.com/
# LLM 模型名称
LLM_MODEL_NAME=deepseek-v4-flash
# 采样温度（0.0-2.0，知识问答建议低值）
LLM_TEMPERATURE=0.1
# 单次 LLM 请求超时时间（秒）
LLM_REQUEST_TIMEOUT=60

# --- Embedding ---
# Embedding 提供方：local（本地 sentence-transformers 模型）/ api（在线 API）
EMBEDDING_PROVIDER=local
# Embedding 模型名称（local 模式下为 HuggingFace 模型 ID）
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
# local 模式首次运行需从 HuggingFace 下载模型权重（约 100MB）。
# 国内网络下载慢或失败时，取消下面注释以使用镜像站加速：
# HF_ENDPOINT=https://hf-mirror.com

# --- 路径（一般无需修改，默认相对项目根目录） ---
# 原始企业制度文档目录
RAW_DOCS_DIR=data/raw_docs
# Chroma 向量库持久化目录
VECTOR_DB_DIR=data/vector_db
# Chroma collection 名称
CHROMA_COLLECTION_NAME=enterprise_knowledge

# --- RAG 参数 ---
# 文档切分策略：fixed（固定长度）/ recursive（递归字符切分，优先段落/句子边界）
CHUNKING_STRATEGY=recursive
# 单个文本块的目标长度（字符数）
CHUNK_SIZE=500
# 相邻文本块之间的重叠长度（字符数）
CHUNK_OVERLAP=50
# 相似度检索返回的候选文档数量
RETRIEVAL_TOP_K=4
# 相似度分数阈值（0.0-1.0），低于该值的检索结果将被过滤
RETRIEVAL_SCORE_THRESHOLD=0.3

# --- Agent 参数 ---
# 工具调用最大轮次，防止死循环
MAX_TOOL_ROUNDS=3

# --- 会话记忆 ---
# SQLite 会话库路径（相对项目根或绝对路径）
SESSION_DB_PATH=data/sessions.db
# 注入 Prompt 的最近完整问答轮数；亦为历史摘要保留窗口（超过 轮数×2 条消息才摘要更早部分）
MAX_HISTORY_TURNS=6
# 多轮场景是否启用 Query Rewrite
ENABLE_QUERY_REWRITE=true

# --- 上下文预算 ---
MAX_HISTORY_CHARS=2000
MAX_RETRIEVAL_CHARS=3000
MAX_TOOL_RESULT_CHARS=1500

# --- 检索模式 ---
# vector=纯向量 / hybrid=BM25+向量 RRF（推荐）
RETRIEVAL_MODE=hybrid
HYBRID_RRF_K=60
HYBRID_BM25_TOP_K=8

# --- 文档密级 ACL（角色由登录 token 决定） ---
ENABLE_ACCESS_CONTROL=true
DOC_ACCESS_PATH=data/doc_access.json

# --- 登录鉴权（工号+密码 → Bearer token） ---
# token HMAC 签名密钥（生产环境务必改为随机长串）
AUTH_SECRET_KEY=dev-only-change-me-eka-auth-secret
# token 有效小时数
AUTH_TOKEN_EXPIRE_HOURS=24
# 演示用户花名册（工号/姓名/角色/密码哈希）
USERS_FILE=data/users.json

# --- 日志 ---
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
